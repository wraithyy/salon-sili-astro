---
import { contact } from "../data/contact"
---

<section id="kde-nas-najdete" class="py-20 sm:py-28 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <p class="text-gold text-sm uppercase tracking-[0.2em] mb-3 font-medium">
        Navštivte nás
      </p>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal">
        Kde nás najdete
      </h2>
      <div class="w-16 h-0.5 bg-gold mx-auto mt-6"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
      <!-- Map -->
      <div class="reveal rounded-2xl overflow-hidden shadow-lg aspect-[4/3]">
        <iframe
          src={contact.mapUrl}
          class="w-full h-full border-0"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mapa - Salon SILI"
        ></iframe>
      </div>

      <!-- Info -->
      <div class="reveal space-y-8">
        <div>
          <h3 class="font-display text-xl font-semibold text-charcoal mb-2">
            Adresa
          </h3>
          <p class="text-charcoal-light leading-relaxed">
            {contact.address.street}<br />
            {contact.address.city}<br />
            {contact.address.zip}
          </p>
          <a
            href={contact.mapLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-gold hover:text-gold-dark transition-colors mt-3 text-sm font-medium"
          >
            Otevřít v Google Maps
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>

        <div>
          <h3 class="font-display text-xl font-semibold text-charcoal mb-2">
            Otevírací doba
          </h3>
          <div class="space-y-2">
            {contact.hours.map((h) => (
              <div class="flex justify-between text-sm">
                <span class="text-charcoal font-medium">{h.day}</span>
                <span class="text-charcoal-light">{h.time}</span>
              </div>
            ))}
          </div>
        </div>

        <a
          href={contact.mapLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-8 py-3.5 bg-gold text-white font-medium rounded-full hover:bg-gold-dark transition-colors duration-300 text-sm uppercase tracking-wider"
        >
          Navigovat do salónu
        </a>
      </div>
    </div>
  </div>
</section>
