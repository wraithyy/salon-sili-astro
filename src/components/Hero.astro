---

---

<section
  class="relative min-h-screen flex items-end lg:items-center overflow-hidden"
  id="hero"
>
  <!-- Solid gradient background -->
  <div
    class="absolute inset-0 gradient-animate bg-gradient-to-br from-charcoal via-charcoal-light to-charcoal"
  ></div>

  <!-- Decorative overlay -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_30%_50%,_transparent_0%,_rgba(0,0,0,0.4)_100%)]"></div>

  <!-- Brand brush accent — asymmetric, visible -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <img
      src={`${import.meta.env.BASE_URL}/img/brush-sm.jpg`}
      alt=""
      class="hero-brush"
      loading="eager"
      width="1600"
      height="900"
    />
  </div>

  <!-- Ambient blobs -->
  <div class="absolute inset-0 overflow-hidden" aria-hidden="true" id="ambient-blobs">
    <div class="ambient-blob ambient-blob--gold"></div>
    <div class="ambient-blob ambient-blob--rose"></div>
  </div>

  <!-- Gold accent line -->
  <div class="absolute left-[8%] top-[15%] bottom-[15%] w-px bg-gradient-to-b from-transparent via-gold/30 to-transparent hidden lg:block" aria-hidden="true"></div>

  <!-- Content — left-aligned, asymmetric -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 sm:px-10 lg:px-16 pb-24 lg:pb-0">
    <div class="max-w-xl lg:max-w-2xl">
      <p
        class="text-gold-light text-xs sm:text-sm uppercase tracking-[0.35em] mb-5 sm:mb-7 font-medium"
      >
        Liberec &middot; nám. Dr. E. Beneše
      </p>
      <h1 class="text-5xl sm:text-7xl lg:text-[6.5rem] text-white font-bold leading-[0.9] mb-6 sm:mb-8">
        <span class="font-display block">Salon</span>
        <span class="font-brand text-gold tracking-wide block mt-1">SILI</span>
      </h1>

      <!-- Decorative dash -->
      <div class="w-12 h-0.5 bg-gold/60 mb-6 sm:mb-8" aria-hidden="true"></div>

      <p class="text-white/65 text-base sm:text-lg max-w-md leading-relaxed mb-10 sm:mb-14">
        Soukromý kosmetický salón v&nbsp;centru Liberce.
        Profesionální pedikúra, podologie a&nbsp;manikúra.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="#cenik"
          class="inline-flex items-center justify-center px-8 py-3.5 bg-gold text-white font-medium rounded-full hover:bg-gold-dark transition-colors duration-300 text-sm uppercase tracking-wider"
        >
          Zobrazit ceník
        </a>
        <a
          href="#kontakt"
          class="inline-flex items-center justify-center px-8 py-3.5 border border-white/25 text-white/80 font-medium rounded-full hover:bg-white/10 hover:text-white transition-all duration-300 text-sm uppercase tracking-wider"
        >
          Kontaktujte nás
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 scroll-pulse" aria-hidden="true">
    <svg class="w-5 h-5 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>

<style>
  .hero-brush {
    position: absolute;
    right: -4%;
    top: 42%;
    transform: translateY(-50%) rotate(-3deg);
    width: min(62vw, 820px);
    opacity: 0.42;
    mix-blend-mode: soft-light;
    filter: saturate(0.85) contrast(1.05);
    mask-image: radial-gradient(ellipse 72% 65% at 55% 50%, black 30%, transparent 85%);
    -webkit-mask-image: radial-gradient(ellipse 72% 65% at 55% 50%, black 30%, transparent 85%);
  }

  .ambient-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.09;
    pointer-events: none;
    will-change: transform;
  }

  .ambient-blob--gold {
    width: 50vw;
    height: 50vw;
    max-width: 550px;
    max-height: 550px;
    background: radial-gradient(circle, var(--color-gold) 0%, transparent 70%);
    top: -15%;
    right: 10%;
    animation: drift-a 25s ease-in-out infinite alternate;
  }

  .ambient-blob--rose {
    width: 35vw;
    height: 35vw;
    max-width: 400px;
    max-height: 400px;
    background: radial-gradient(circle, var(--color-rose) 0%, transparent 70%);
    bottom: -5%;
    left: 20%;
    animation: drift-b 30s ease-in-out infinite alternate;
  }

  .scroll-pulse {
    animation: pulse-fade 3s ease-in-out infinite;
  }

  @keyframes drift-a {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(8vw, 10vh) scale(1.12); }
  }

  @keyframes drift-b {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(-6vw, -8vh) scale(1.08); }
  }

  @keyframes pulse-fade {
    0%, 100% { opacity: 0.3; transform: translateX(-50%) translateY(0); }
    50%      { opacity: 0.6; transform: translateX(-50%) translateY(6px); }
  }

  @media (max-width: 768px) {
    .hero-brush {
      width: 100vw;
      right: -25%;
      top: 30%;
      opacity: 0.3;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ambient-blob {
      animation: none !important;
    }

    .scroll-pulse {
      animation: none !important;
      opacity: 0.3;
    }

    .hero-brush {
      transform: translateY(-50%);
    }
  }
</style>
