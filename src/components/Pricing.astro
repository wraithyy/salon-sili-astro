---
import { pricing } from "../data/pricing"

const categoryIcons: Record<string, string> = {
  "Pedikúra": `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
  "Podologie": `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>`,
  "Manikúra": `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11m0-5.5a1.5 1.5 0 013 0v3m0 0V11"/></svg>`,
}
---

<section id="cenik" class="py-20 sm:py-28 bg-cream relative overflow-hidden">
  <!-- Decorative side accent -->
  <div class="absolute right-0 top-20 bottom-20 w-px bg-gradient-to-b from-transparent via-gold/15 to-transparent hidden lg:block" aria-hidden="true"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <p class="text-gold text-sm uppercase tracking-[0.2em] mb-3 font-medium">
        Transparentní ceny
      </p>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal">
        Ceník
      </h2>
      <div class="w-16 h-0.5 bg-gold mx-auto mt-6"></div>
    </div>

    <!-- Editorial staggered layout -->
    <div class="space-y-8 lg:space-y-0 lg:grid lg:grid-cols-3 lg:gap-8">
      {pricing.map((category, i) => (
        <div
          class:list={[
            "reveal pricing-column",
            i === 1 ? "lg:mt-10" : "",
          ]}
          style={`transition-delay: ${i * 120}ms`}
        >
          <!-- Category header -->
          <div class="flex items-center gap-3 mb-6">
            <div class="w-9 h-9 rounded-lg bg-gold/10 text-gold flex items-center justify-center">
              <Fragment set:html={categoryIcons[category.category] || ''} />
            </div>
            <h3 class="font-display text-2xl font-semibold text-charcoal">
              {category.category}
            </h3>
          </div>

          <!-- Items -->
          <div class="space-y-0">
            {category.items.map((item, j) => (
              <div class:list={[
                "pricing-item flex items-baseline justify-between gap-3 py-4",
                j < category.items.length - 1 ? "border-b border-charcoal/5" : "",
              ]}>
                <div class="flex-1 min-w-0">
                  <span class="text-charcoal text-[0.9rem] font-medium">{item.name}</span>
                  {item.note && (
                    <span class="text-charcoal-light/70 text-xs ml-1.5">({item.note})</span>
                  )}
                </div>
                <span class="text-gold-dark font-semibold tabular-nums whitespace-nowrap text-[0.95rem]">
                  {item.price}&nbsp;Kč
                </span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing-column {
    background: linear-gradient(180deg, #ffffff 0%, #fdfbf7 100%);
    border-radius: 1.25rem;
    padding: 2rem 2rem 1.5rem;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.03);
    transition: box-shadow 0.3s ease;
  }

  .pricing-column:hover {
    box-shadow: 0 6px 24px rgba(184, 155, 94, 0.08);
  }

  .pricing-item {
    transition: background-color 0.2s ease;
  }

  .pricing-item:hover {
    background-color: rgba(184, 155, 94, 0.04);
    margin-inline: -0.75rem;
    padding-inline: 0.75rem;
    border-radius: 0.5rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .pricing-column,
    .pricing-item {
      transition: none !important;
    }

    .pricing-column:nth-child(2) {
      margin-top: 0 !important;
    }
  }
</style>
