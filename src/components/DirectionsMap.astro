---
import { contact } from "../data/contact"
---

<section id="jak-se-k-nam-dostat" class="py-20 sm:py-28 bg-cream">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <p class="text-gold text-sm uppercase tracking-[0.2em] mb-3 font-medium">
        Kudy k nam
      </p>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal">
        Jak se k nam dostat
      </h2>
      <div class="w-16 h-0.5 bg-gold mx-auto mt-6"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
      <!-- SVG Map -->
      <div class="reveal">
        <div class="relative bg-white rounded-2xl shadow-lg p-6 sm:p-8 overflow-hidden">
          <svg
            viewBox="0 0 500 440"
            class="w-full h-auto"
            role="img"
            aria-label="Orientacni schema pristupu do Salon SILI pruchodem pres OC Plaza"
          >
            <!-- Background -->
            <rect width="500" height="440" fill="#faf7f2" rx="8" />

            <!-- ============================================ -->
            <!-- GEOGRAPHIC ORIENTATION: North = top           -->
            <!-- Top: nam. Dr. E. Benese (Benesovo nam.)       -->
            <!-- Bottom: Soukenne namesti                       -->
            <!-- Right: Palachova ulice                         -->
            <!-- Left: ul. 5. kvetna                            -->
            <!-- ============================================ -->

            <!-- Streets -->
            <g fill="#f0ebe3" stroke="#e0d8cc" stroke-width="0.5">
              <!-- nam. Dr. E. Benese (wide horizontal, top) -->
              <rect x="20" y="40" width="460" height="65" rx="3" />
              <!-- Soukenne namesti (wide horizontal, bottom) -->
              <rect x="20" y="310" width="460" height="55" rx="3" />
              <!-- Palachova ulice (vertical, right side) -->
              <rect x="380" y="40" width="48" height="325" rx="2" />
              <!-- ul. 5. kvetna (vertical, left side) -->
              <rect x="70" y="40" width="42" height="325" rx="2" />
            </g>

            <!-- Street labels -->
            <text x="225" y="68" text-anchor="middle" fill="#4a4a4a" font-size="11" font-family="Inter, system-ui" font-weight="600" opacity="0.75">
              nam. Dr. E. Benese
            </text>
            <text x="225" y="82" text-anchor="middle" fill="#4a4a4a" font-size="8" font-family="Inter, system-ui" opacity="0.5">
              (Benesovo namesti)
            </text>
            <text x="225" y="342" text-anchor="middle" fill="#4a4a4a" font-size="11" font-family="Inter, system-ui" font-weight="600" opacity="0.75">
              Soukenne namesti
            </text>
            <!-- Palachova - vertical label -->
            <text transform="translate(414, 210) rotate(90)" text-anchor="middle" fill="#4a4a4a" font-size="9" font-family="Inter, system-ui" font-weight="500" opacity="0.6">
              Palachova ul.
            </text>
            <!-- 5. kvetna - vertical label -->
            <text transform="translate(82, 210) rotate(-90)" text-anchor="middle" fill="#4a4a4a" font-size="9" font-family="Inter, system-ui" font-weight="500" opacity="0.6">
              ul. 5. kvetna
            </text>

            <!-- Building blocks (neutral) -->
            <g fill="#e8e2d8" stroke="#d4cec4" stroke-width="0.5">
              <!-- Block left of Plaza -->
              <rect x="112" y="120" width="85" height="185" rx="4" />
              <!-- Block right of Plaza -->
              <rect x="310" y="120" width="70" height="185" rx="4" />
            </g>

            <!-- OC Plaza building -->
            <rect x="197" y="185" width="113" height="120" rx="5" fill="#dcc9a0" fill-opacity="0.25" stroke="#c9a96e" stroke-width="1.2" />
            <text x="253" y="230" text-anchor="middle" fill="#a8894e" font-size="12" font-family="Inter, system-ui" font-weight="700">
              OC Plaza
            </text>
            <text x="253" y="248" text-anchor="middle" fill="#a8894e" font-size="8" font-family="Inter, system-ui" opacity="0.7">
              nakupni centrum
            </text>

            <!-- OC Plaza entrance marker (south side, facing Soukenne nam.) -->
            <rect x="233" y="295" width="40" height="15" rx="3" fill="#dcc9a0" fill-opacity="0.5" stroke="#c9a96e" stroke-width="0.8" />
            <text x="253" y="306" text-anchor="middle" fill="#a8894e" font-size="7" font-family="Inter, system-ui" font-weight="600">
              VSTUP
            </text>

            <!-- Passage / Pruchod (through OC Plaza, south to north) -->
            <rect x="233" y="120" width="40" height="75" rx="2" fill="#faf7f2" stroke="#c9a96e" stroke-width="1.5" stroke-dasharray="6 3" />
            <text x="253" y="155" text-anchor="middle" fill="#c9a96e" font-size="8" font-family="Inter, system-ui" font-weight="600" letter-spacing="0.5">
              PRUCHOD
            </text>
            <text x="253" y="167" text-anchor="middle" fill="#c9a96e" font-size="7" font-family="Inter, system-ui" opacity="0.7">
              pasaz
            </text>

            <!-- Salon SILI marker (north exit of passage, on Benesovo nam.) -->
            <g class="salon-marker">
              <!-- Building highlight -->
              <rect x="218" y="96" width="70" height="24" rx="4" fill="#c9a96e" fill-opacity="0.15" stroke="#c9a96e" stroke-width="1.5" />
              <text x="253" y="112" text-anchor="middle" fill="#c9a96e" font-size="8" font-family="Inter, system-ui" font-weight="700" letter-spacing="0.5">
                SALON SILI
              </text>

              <!-- Pin icon above salon -->
              <g transform="translate(253, 78)">
                <circle cx="0" cy="0" r="10" fill="#c9a96e" opacity="0.15" class="pin-pulse" />
                <path d="M0-8 C-4.4-8-8-4.4-8 0 C-8 4.4 0 12 0 12 S8 4.4 8 0 C8-4.4 4.4-8 0-8Z" fill="#c9a96e" />
                <circle cx="0" cy="0" r="3" fill="#ffffff" />
              </g>
            </g>

            <!-- Walking route: from entrance (south) through passage to salon (north) -->
            <path
              d="M253 295 L253 195 L253 120 L253 96"
              fill="none"
              stroke="#c9a96e"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-dasharray="1 6"
              class="route-path"
            />

            <!-- Route start marker (at entrance on Soukenne nam.) -->
            <circle cx="253" cy="295" r="5" fill="#c9a96e" opacity="0.6" />
            <circle cx="253" cy="295" r="2.5" fill="#c9a96e" />

            <!-- Walking person icon at start -->
            <g transform="translate(270, 288)" fill="#c9a96e" opacity="0.8">
              <circle cx="0" cy="-4" r="2.5" />
              <path d="M0 -1 L0 6 M-3 3 L0 0 L3 3 M-2 10 L0 6 L2 10" stroke="#c9a96e" stroke-width="1.2" fill="none" stroke-linecap="round" />
            </g>

            <!-- Direction arrow along the route (pointing north/up) -->
            <polygon points="253,140 248,150 258,150" fill="#c9a96e" opacity="0.6" />

            <!-- Legend -->
            <g transform="translate(20, 390)">
              <line x1="0" y1="0" x2="20" y2="0" stroke="#c9a96e" stroke-width="2.5" stroke-dasharray="1 6" stroke-linecap="round" />
              <text x="28" y="4" fill="#4a4a4a" font-size="9" font-family="Inter, system-ui">Pesi trasa pruchodem</text>

              <rect x="160" y="-6" width="12" height="12" rx="2" fill="#dcc9a0" fill-opacity="0.3" stroke="#c9a96e" stroke-width="0.8" />
              <text x="178" y="4" fill="#4a4a4a" font-size="9" font-family="Inter, system-ui">OC Plaza</text>

              <path d="M270-4 C267.8-4 266-1.8 266 1 C266 3.8 270 9 270 9 S274 3.8 274 1 C274-1.8 272.2-4 270-4Z" fill="#c9a96e" />
              <text x="280" y="4" fill="#4a4a4a" font-size="9" font-family="Inter, system-ui">Salon SILI</text>
            </g>

            <!-- Compass (top-right corner) -->
            <g transform="translate(455, 30)">
              <circle cx="0" cy="0" r="14" fill="none" stroke="#c9a96e" stroke-width="0.8" opacity="0.4" />
              <text x="0" y="-4" text-anchor="middle" fill="#c9a96e" font-size="8" font-family="Inter, system-ui" font-weight="700" opacity="0.6">S</text>
              <line x1="0" y1="4" x2="0" y2="10" stroke="#c9a96e" stroke-width="0.8" opacity="0.4" />
            </g>

            <!-- Decorative corner accents -->
            <line x1="15" y1="15" x2="15" y2="30" stroke="#c9a96e" stroke-width="1" opacity="0.3" />
            <line x1="15" y1="15" x2="30" y2="15" stroke="#c9a96e" stroke-width="1" opacity="0.3" />
            <line x1="485" y1="15" x2="485" y2="30" stroke="#c9a96e" stroke-width="1" opacity="0.3" />
            <line x1="470" y1="15" x2="485" y2="15" stroke="#c9a96e" stroke-width="1" opacity="0.3" />
            <line x1="15" y1="425" x2="15" y2="410" stroke="#c9a96e" stroke-width="1" opacity="0.3" />
            <line x1="15" y1="425" x2="30" y2="425" stroke="#c9a96e" stroke-width="1" opacity="0.3" />
            <line x1="485" y1="425" x2="485" y2="410" stroke="#c9a96e" stroke-width="1" opacity="0.3" />
            <line x1="470" y1="425" x2="485" y2="425" stroke="#c9a96e" stroke-width="1" opacity="0.3" />

            <!-- "Orientacni schema" note -->
            <text x="250" y="432" text-anchor="middle" fill="#4a4a4a" font-size="8" font-family="Inter, system-ui" font-style="italic" opacity="0.45">
              Orientacni schema -- zjednoduseno
            </text>
          </svg>

          <style>
            .pin-pulse {
              animation: pulse-ring 2s ease-out infinite;
            }

            @keyframes pulse-ring {
              0% {
                r: 10;
                opacity: 0.15;
              }
              100% {
                r: 20;
                opacity: 0;
              }
            }

            .route-path {
              animation: dash-flow 3s linear infinite;
            }

            @keyframes dash-flow {
              to {
                stroke-dashoffset: -42;
              }
            }
          </style>
        </div>
      </div>

      <!-- Directions -->
      <div class="reveal space-y-8">
        <div>
          <h3 class="font-display text-xl sm:text-2xl font-semibold text-charcoal mb-6">
            Pruchodem pres Plazu za minutu
          </h3>
          <p class="text-charcoal-light leading-relaxed mb-8">
            Salon se nachazi na Benesove namesti 2, primo u vychodu z pasaze OC Plaza.
            Nejsnaze se k nam dostanete pruchodem ze Soukenneho namesti.
          </p>
        </div>

        <ol class="space-y-6">
          {contact.directions.map((d, i) => (
            <li class="flex gap-4 items-start">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-gold/10 text-gold font-display font-bold text-sm flex items-center justify-center border border-gold/20">
                {d.step}
              </span>
              <span class="text-charcoal-light leading-relaxed pt-1">
                {d.text}
              </span>
            </li>
          ))}
        </ol>

        <div class="pt-4">
          <a
            href={contact.mapLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-gold text-white font-medium rounded-full hover:bg-gold-dark transition-colors duration-300 text-sm uppercase tracking-wider"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Otevrit v mapach
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
