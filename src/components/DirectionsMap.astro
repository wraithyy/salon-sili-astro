---
import { contact } from "../data/contact"
---

<section id="jak-se-k-nam-dostat" class="py-20 sm:py-28 bg-cream">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 reveal">
      <p class="text-gold text-sm uppercase tracking-[0.2em] mb-3 font-medium">
        Kudy k nám
      </p>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal">
        Orientační mapka vstupu
      </h2>
      <div class="w-16 h-0.5 bg-gold mx-auto mt-6"></div>
    </div>

    <div class="reveal">
      <div class="relative bg-white rounded-2xl shadow-lg p-5 sm:p-8 overflow-hidden">
        <svg
          viewBox="0 0 900 560"
          class="w-full h-auto"
          role="img"
          aria-label="Orientační schéma vstupu do Salonu SILI od OC Plaza a z náměstí Dr. E. Beneše"
        >
          <rect width="900" height="560" fill="#faf7f2" rx="12" />

          <!-- ulice a bloky -->
          <rect x="38" y="68" width="824" height="86" rx="8" fill="#efe8dc" />
          <text x="450" y="120" text-anchor="middle" fill="#6a6256" font-size="22" font-family="Inter, system-ui" font-weight="600">
            nám. Dr. E. Beneše
          </text>

          <rect x="38" y="392" width="824" height="86" rx="8" fill="#efe8dc" />
          <text x="450" y="444" text-anchor="middle" fill="#6a6256" font-size="20" font-family="Inter, system-ui" font-weight="600">
            Soukenné náměstí
          </text>

          <rect x="85" y="160" width="180" height="220" rx="10" fill="#e7dfd3" />
          <rect x="635" y="160" width="180" height="220" rx="10" fill="#e7dfd3" />

          <!-- plaza + průchod -->
          <rect x="300" y="184" width="300" height="196" rx="12" fill="#dcc9a0" fill-opacity="0.3" stroke="#b89b5e" stroke-width="2"/>
          <text x="450" y="255" text-anchor="middle" fill="#9a7f44" font-size="28" font-family="Inter, system-ui" font-weight="700">OC Plaza</text>
          <text x="450" y="282" text-anchor="middle" fill="#9a7f44" font-size="14" font-family="Inter, system-ui">(parkování)</text>

          <rect x="423" y="146" width="54" height="238" rx="7" fill="#fffaf0" stroke="#b89b5e" stroke-width="2" stroke-dasharray="8 6" />
          <text x="450" y="206" text-anchor="middle" fill="#9a7f44" font-size="14" font-family="Inter, system-ui" font-weight="700">PRŮCHOD</text>
          <text x="450" y="224" text-anchor="middle" fill="#9a7f44" font-size="12" font-family="Inter, system-ui">skrz budovu</text>

          <!-- salon -->
          <rect x="392" y="92" width="116" height="42" rx="8" fill="#b89b5e" fill-opacity="0.12" stroke="#b89b5e" stroke-width="2"/>
          <text x="450" y="118" text-anchor="middle" fill="#9a7f44" font-size="16" font-family="Inter, system-ui" font-weight="700">SALON SILI</text>

          <!-- modrá trasa -->
          <path d="M450 435 L450 382 L450 146 L450 113" fill="none" stroke="#2563eb" stroke-width="7" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="450" cy="435" r="8" fill="#2563eb" />

          <!-- červená trasa -->
          <path d="M300 112 L392 112" fill="none" stroke="#dc2626" stroke-width="7" stroke-linecap="round" />
          <circle cx="300" cy="112" r="8" fill="#dc2626" />

          <!-- šipky -->
          <polygon points="450,126 440,146 460,146" fill="#2563eb"/>
          <polygon points="374,102 392,112 374,122" fill="#dc2626"/>

          <!-- legenda -->
          <rect x="48" y="494" width="804" height="48" rx="10" fill="#f4ede2" />
          <line x1="84" y1="519" x2="130" y2="519" stroke="#2563eb" stroke-width="6" stroke-linecap="round"/>
          <text x="142" y="524" fill="#4a433a" font-size="16" font-family="Inter, system-ui">Modrá: od OC Plaza (parkování) přes průchod</text>

          <line x1="540" y1="519" x2="586" y2="519" stroke="#dc2626" stroke-width="6" stroke-linecap="round"/>
          <text x="598" y="524" fill="#4a433a" font-size="16" font-family="Inter, system-ui">Červená: z náměstí Dr. E. Beneše</text>
        </svg>

        <p class="text-xs text-charcoal-light/70 mt-3 italic">Orientační schéma</p>

        <div class="mt-6 flex justify-center">
          <a
            href={contact.mapLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-gold text-white font-medium rounded-full hover:bg-gold-dark transition-colors duration-300 text-sm uppercase tracking-wider"
          >
            Otevřít v mapách
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
