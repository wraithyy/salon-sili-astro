---
import { contact } from "../data/contact"
---

<section id="jak-se-k-nam-dostat" class="py-20 sm:py-28 bg-cream">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <p class="text-gold text-sm uppercase tracking-[0.2em] mb-3 font-medium">
        Kudy k nám
      </p>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal">
        Jak se k nám dostat
      </h2>
      <div class="w-16 h-0.5 bg-gold mx-auto mt-6"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
      <!-- SVG Map -->
      <div class="reveal">
        <div class="relative bg-white rounded-2xl shadow-lg p-6 sm:p-8 overflow-hidden">
          <svg
            viewBox="0 0 500 400"
            class="w-full h-auto"
            role="img"
            aria-label="Stylizovaná mapka přístupu do Salon SILI průchodem u OC Plaza"
          >
            <!-- Background -->
            <rect width="500" height="400" fill="#faf7f2" rx="8" />

            <!-- Streets -->
            <g fill="#f0ebe3" stroke="#e0d8cc" stroke-width="0.5">
              <!-- Soukenné náměstí (horizontal, top area) -->
              <rect x="30" y="80" width="440" height="60" rx="2" />
              <!-- Benešovo náměstí (horizontal, bottom area) -->
              <rect x="30" y="260" width="440" height="60" rx="2" />
              <!-- Connecting street left -->
              <rect x="60" y="80" width="50" height="240" rx="2" />
              <!-- Connecting street right -->
              <rect x="380" y="80" width="50" height="240" rx="2" />
            </g>

            <!-- Street labels -->
            <text x="250" y="106" text-anchor="middle" fill="#4a4a4a" font-size="11" font-family="Inter, system-ui" font-weight="500" opacity="0.7">
              Soukenné náměstí
            </text>
            <text x="250" y="286" text-anchor="middle" fill="#4a4a4a" font-size="11" font-family="Inter, system-ui" font-weight="500" opacity="0.7">
              Benešovo náměstí
            </text>

            <!-- Buildings block -->
            <g fill="#e8e2d8" stroke="#d4cec4" stroke-width="0.5">
              <!-- Left block -->
              <rect x="110" y="140" width="100" height="120" rx="4" />
              <!-- Right block -->
              <rect x="290" y="140" width="90" height="120" rx="4" />
            </g>

            <!-- OC Plaza building -->
            <rect x="210" y="140" width="80" height="55" rx="4" fill="#dcc9a0" fill-opacity="0.3" stroke="#c9a96e" stroke-width="1" />
            <text x="250" y="164" text-anchor="middle" fill="#a8894e" font-size="10" font-family="Inter, system-ui" font-weight="600">
              OC Plaza
            </text>
            <text x="250" y="180" text-anchor="middle" fill="#a8894e" font-size="8" font-family="Inter, system-ui" opacity="0.7">
              (vstup)
            </text>

            <!-- Passage / Průchod -->
            <rect x="225" y="195" width="50" height="65" rx="2" fill="#faf7f2" stroke="#c9a96e" stroke-width="1.5" stroke-dasharray="6 3" />
            <text x="250" y="225" text-anchor="middle" fill="#c9a96e" font-size="8" font-family="Inter, system-ui" font-weight="600" letter-spacing="0.5">
              PRUCHOD
            </text>

            <!-- Salon SILI marker -->
            <g class="salon-marker">
              <!-- Building highlight -->
              <rect x="275" y="235" width="50" height="25" rx="4" fill="#c9a96e" fill-opacity="0.15" stroke="#c9a96e" stroke-width="1.5" />
              <text x="300" y="251" text-anchor="middle" fill="#c9a96e" font-size="7" font-family="Inter, system-ui" font-weight="700" letter-spacing="0.3">
                SALON SILI
              </text>

              <!-- Pin icon -->
              <g transform="translate(300, 212)">
                <circle cx="0" cy="0" r="10" fill="#c9a96e" opacity="0.15" class="pin-pulse" />
                <path d="M0-8 C-4.4-8-8-4.4-8 0 C-8 4.4 0 12 0 12 S8 4.4 8 0 C8-4.4 4.4-8 0-8Z" fill="#c9a96e" />
                <circle cx="0" cy="0" r="3" fill="#ffffff" />
              </g>
            </g>

            <!-- Walking route (dotted path from Plaza entrance through passage to salon) -->
            <path
              d="M250 140 L250 195 L250 232 Q250 240 258 240 L275 245"
              fill="none"
              stroke="#c9a96e"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-dasharray="1 6"
              class="route-path"
            />

            <!-- Route arrow start (at Plaza) -->
            <circle cx="250" cy="140" r="5" fill="#c9a96e" opacity="0.6" />
            <circle cx="250" cy="140" r="2.5" fill="#c9a96e" />

            <!-- Walking person icon at start -->
            <g transform="translate(265, 152)" fill="#c9a96e" opacity="0.8">
              <circle cx="0" cy="-4" r="2.5" />
              <path d="M0 -1 L0 6 M-3 3 L0 0 L3 3 M-2 10 L0 6 L2 10" stroke="#c9a96e" stroke-width="1.2" fill="none" stroke-linecap="round" />
            </g>

            <!-- Legend -->
            <g transform="translate(30, 340)">
              <line x1="0" y1="0" x2="20" y2="0" stroke="#c9a96e" stroke-width="2.5" stroke-dasharray="1 6" stroke-linecap="round" />
              <text x="28" y="4" fill="#4a4a4a" font-size="9" font-family="Inter, system-ui">Pesi trasa pruchod</text>

              <rect x="150" y="-6" width="12" height="12" rx="2" fill="#dcc9a0" fill-opacity="0.3" stroke="#c9a96e" stroke-width="0.8" />
              <text x="168" y="4" fill="#4a4a4a" font-size="9" font-family="Inter, system-ui">OC Plaza</text>

              <path d="M280-4 C277.8-4 276-1.8 276 1 C276 3.8 280 9 280 9 S284 3.8 284 1 C284-1.8 282.2-4 280-4Z" fill="#c9a96e" />
              <text x="290" y="4" fill="#4a4a4a" font-size="9" font-family="Inter, system-ui">Salon SILI</text>
            </g>

            <!-- Decorative corner accents -->
            <line x1="15" y1="20" x2="15" y2="35" stroke="#c9a96e" stroke-width="1" opacity="0.3" />
            <line x1="15" y1="20" x2="30" y2="20" stroke="#c9a96e" stroke-width="1" opacity="0.3" />
            <line x1="485" y1="20" x2="485" y2="35" stroke="#c9a96e" stroke-width="1" opacity="0.3" />
            <line x1="470" y1="20" x2="485" y2="20" stroke="#c9a96e" stroke-width="1" opacity="0.3" />
            <line x1="15" y1="380" x2="15" y2="365" stroke="#c9a96e" stroke-width="1" opacity="0.3" />
            <line x1="15" y1="380" x2="30" y2="380" stroke="#c9a96e" stroke-width="1" opacity="0.3" />
            <line x1="485" y1="380" x2="485" y2="365" stroke="#c9a96e" stroke-width="1" opacity="0.3" />
            <line x1="470" y1="380" x2="485" y2="380" stroke="#c9a96e" stroke-width="1" opacity="0.3" />

            <!-- Compass -->
            <g transform="translate(440, 60)">
              <circle cx="0" cy="0" r="14" fill="none" stroke="#c9a96e" stroke-width="0.8" opacity="0.4" />
              <text x="0" y="-5" text-anchor="middle" fill="#c9a96e" font-size="8" font-family="Inter, system-ui" font-weight="700" opacity="0.6">S</text>
              <line x1="0" y1="4" x2="0" y2="10" stroke="#c9a96e" stroke-width="0.8" opacity="0.4" />
            </g>
          </svg>

          <style>
            .pin-pulse {
              animation: pulse-ring 2s ease-out infinite;
            }

            @keyframes pulse-ring {
              0% {
                r: 10;
                opacity: 0.15;
              }
              100% {
                r: 20;
                opacity: 0;
              }
            }

            .route-path {
              animation: dash-flow 3s linear infinite;
            }

            @keyframes dash-flow {
              to {
                stroke-dashoffset: -42;
              }
            }
          </style>
        </div>
      </div>

      <!-- Directions -->
      <div class="reveal space-y-8">
        <div>
          <h3 class="font-display text-xl sm:text-2xl font-semibold text-charcoal mb-6">
            Průchodem u Plazy za minutu
          </h3>
          <p class="text-charcoal-light leading-relaxed mb-8">
            Salon se nachází na Benešově náměstí 2, nejsnáze se k nám dostanete průchodem od OC Plaza.
          </p>
        </div>

        <ol class="space-y-6">
          {contact.directions.map((d, i) => (
            <li class="flex gap-4 items-start">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-gold/10 text-gold font-display font-bold text-sm flex items-center justify-center border border-gold/20">
                {d.step}
              </span>
              <span class="text-charcoal-light leading-relaxed pt-1">
                {d.text}
              </span>
            </li>
          ))}
        </ol>

        <div class="pt-4">
          <a
            href={contact.mapLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-gold text-white font-medium rounded-full hover:bg-gold-dark transition-colors duration-300 text-sm uppercase tracking-wider"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Otevřít v mapách
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
