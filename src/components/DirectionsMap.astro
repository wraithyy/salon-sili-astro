---
import { contact } from "../data/contact"
---

<section id="jak-se-k-nam-dostat" class="py-20 sm:py-28 bg-cream">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 reveal">
      <p class="text-gold text-sm uppercase tracking-[0.2em] mb-3 font-medium">
        Kudy k nám
      </p>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal">
        Orientační mapa
      </h2>
      <div class="w-16 h-0.5 bg-gold mx-auto mt-6"></div>
    </div>

    <div class="reveal">
      <div class="relative bg-white rounded-2xl shadow-lg overflow-hidden">
        <!-- Map -->
        <div class="p-4 sm:p-6 lg:p-8">
          <svg
            viewBox="0 0 880 520"
            class="w-full h-auto"
            role="img"
            aria-label="Orientační schéma: modrá trasa od OC Plaza přes průchod, červená trasa z náměstí Dr. E. Beneše"
          >
            <defs>
              <marker id="arrow-blue" viewBox="0 0 10 8" refX="8" refY="4" markerWidth="8" markerHeight="6" orient="auto">
                <path d="M0 0 L10 4 L0 8 Z" fill="#2563eb" />
              </marker>
              <marker id="arrow-red" viewBox="0 0 10 8" refX="8" refY="4" markerWidth="8" markerHeight="6" orient="auto">
                <path d="M0 0 L10 4 L0 8 Z" fill="#dc2626" />
              </marker>
            </defs>

            <!-- Background -->
            <rect width="880" height="520" fill="#faf7f2" rx="8" />

            <!-- Street: nám. Dr. E. Beneše -->
            <rect x="30" y="60" width="820" height="72" rx="6" fill="#f0ebe3" />
            <text x="440" y="104" text-anchor="middle" fill="#8a7e6e" font-size="15" font-family="Inter, system-ui" font-weight="600" letter-spacing="0.05em">
              NÁM. DR. E. BENEŠE
            </text>

            <!-- Street: Soukenné nám. -->
            <rect x="30" y="380" width="820" height="68" rx="6" fill="#f0ebe3" />
            <text x="440" y="420" text-anchor="middle" fill="#8a7e6e" font-size="14" font-family="Inter, system-ui" font-weight="500" letter-spacing="0.04em">
              SOUKENNÉ NÁM.
            </text>

            <!-- City blocks -->
            <rect x="60" y="138" width="170" height="234" rx="8" fill="#efe8dc" />
            <rect x="650" y="138" width="170" height="234" rx="8" fill="#efe8dc" />

            <!-- OC Plaza -->
            <rect x="280" y="168" width="320" height="204" rx="10" fill="#e8dcc5" fill-opacity="0.35" stroke="#c9a96e" stroke-width="1.5" />
            <text x="440" y="255" text-anchor="middle" fill="#9a7f44" font-size="22" font-family="Inter, system-ui" font-weight="700" letter-spacing="0.03em">OC PLAZA</text>
            <text x="440" y="278" text-anchor="middle" fill="#b89b5e" font-size="11" font-family="Inter, system-ui" font-weight="500" letter-spacing="0.06em">PARKOVÁNÍ</text>

            <!-- Passage -->
            <rect x="412" y="130" width="56" height="242" rx="6" fill="#fffbf2" stroke="#c9a96e" stroke-width="1.5" stroke-dasharray="6 5" />
            <text x="440" y="196" text-anchor="middle" fill="#9a7f44" font-size="10" font-family="Inter, system-ui" font-weight="700" letter-spacing="0.06em" transform="rotate(-90, 440, 196)">PRŮCHOD</text>

            <!-- Salon marker -->
            <rect x="400" y="76" width="80" height="38" rx="6" fill="#b89b5e" />
            <text x="440" y="100" text-anchor="middle" fill="#ffffff" font-size="12" font-family="Inter, system-ui" font-weight="700" letter-spacing="0.04em">SALON SILI</text>

            <!-- Blue route: from Soukenné through passage to salon -->
            <path
              d="M440 415 L440 372 L440 130"
              fill="none"
              stroke="#2563eb"
              stroke-width="5"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-dasharray="0"
              marker-end="url(#arrow-blue)"
            />
            <!-- Blue start dot -->
            <circle cx="440" cy="415" r="6" fill="#2563eb" />
            <circle cx="440" cy="415" r="3" fill="#ffffff" />

            <!-- Red route: from náměstí to salon -->
            <path
              d="M285 95 L400 95"
              fill="none"
              stroke="#dc2626"
              stroke-width="5"
              stroke-linecap="round"
              marker-end="url(#arrow-red)"
            />
            <!-- Red start dot -->
            <circle cx="285" cy="95" r="6" fill="#dc2626" />
            <circle cx="285" cy="95" r="3" fill="#ffffff" />

            <!-- Legend bar -->
            <rect x="30" y="462" width="820" height="44" rx="8" fill="#f4ede2" />

            <!-- Blue legend -->
            <circle cx="60" cy="484" r="4" fill="#2563eb" />
            <line x1="72" y1="484" x2="108" y2="484" stroke="#2563eb" stroke-width="4" stroke-linecap="round" />
            <text x="118" y="489" fill="#5a5247" font-size="13" font-family="Inter, system-ui" font-weight="500">Od OC Plaza přes průchod</text>

            <!-- Red legend -->
            <circle cx="490" cy="484" r="4" fill="#dc2626" />
            <line x1="502" y1="484" x2="538" y2="484" stroke="#dc2626" stroke-width="4" stroke-linecap="round" />
            <text x="548" y="489" fill="#5a5247" font-size="13" font-family="Inter, system-ui" font-weight="500">Z nám. Dr. E. Beneše</text>
          </svg>
        </div>

        <!-- CTA -->
        <div class="px-6 pb-6 sm:px-8 sm:pb-8 flex justify-center">
          <a
            href={contact.mapLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-gold text-white font-medium rounded-full hover:bg-gold-dark transition-colors duration-300 text-sm uppercase tracking-wider"
          >
            Otevřít v mapách
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
